<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{{title}}} - Player Accounts</title>
    <link rel="stylesheet" href="/styles.css">
    <script defer src="/login.js"></script>
</head>
<body>
    <div class="container">
        <h1>Login</h1>
        <form id="loginForm">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required>
            
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>
            
            <button type="submit">Login</button>
        </form>
        <div id="userInfo" class="hidden">
            <h2>User Information:</h2>
            <p>ID: <span id="userId"></span></p>
            <p>Username: <span id="userUsername"></span></p>
            <p>Round: <span id="userRound"></span></p>
            <p>Enemies Killed: <span id="userEnemiesKilled"></span></p>
            <p>Times Played: <span id="userTimesPlayed"></span></p>
            <p>Deaths: <span id="userDeaths"></span></p>
            <p>Highest Round: <span id="userHighestRound"></span></p>
        </div>
    </div>
</body>
</html>
